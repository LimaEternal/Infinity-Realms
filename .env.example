# API-ключи
OPENROUTER_API_KEY=sk-твой_ключ_здесь

# Модель AI (бесплатные варианты)
# nvidia/nemotron-nano-9b-v2:free — быстрая и стабильная
# nvidia/nemotron-3-super-120b-a12b:free — мощная
# qwen/qwen3-coder:free — топ качество, но часто rate-limit
# meta-llama/llama-3.2-3b-instruct:free — самая быстрая
AI_MODEL=nvidia/nemotron-nano-9b-v2:free

# Настройки приложения
FLASK_ENV=development
SECRET_KEY=dams-secret-key-change-in-production
